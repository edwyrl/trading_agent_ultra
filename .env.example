# App
APP_ENV=dev

# Database
SUPABASE_DB_URL=postgresql+psycopg://postgres.<project-ref>:<password>@<pooler-host>:6543/postgres?sslmode=require
SUPABASE_SCHEMA=thesis

# Search Providers
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
BOCHA_API_KEY=
BOCHA_BASE_URL=https://api.bochaai.com/v1/web-search

# LLM Registry
LLM_MODELS_CONFIG_PATH=shared/config/llm_models.yaml

# LLM Providers
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# Macro Intel
MACRO_INTEL_TIMEOUT_SECONDS=15
MACRO_INTEL_CONFIG_PATH=macro/config/macro_intel.yaml
MACRO_INTEL_EVENT_LOG_PATH=logs/macro_intel_latest.json
MACRO_INTEL_EDITOR_ROLE=macro_editor
MACRO_INTEL_EDITOR_TIMEOUT_SECONDS=12
MACRO_INTEL_SUMMARIZER_ROLE=macro_summarizer
MACRO_INTEL_SUMMARIZER_TIMEOUT_SECONDS=16

# Email (Resend)
RESEND_API_KEY=
RESEND_BASE_URL=https://api.resend.com/emails
RESEND_FROM_EMAIL=
MACRO_DIGEST_RECIPIENTS_DOC_PATH=docs/macro_digest_recipients.md
MACRO_DIGEST_SUBJECT_PREFIX=[Macro Digest]
